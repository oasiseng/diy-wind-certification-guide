{
  "name": "@oasis/asce7-calculator",
  "version": "1.0.0",
  "description": "ASCE 7-22 wind pressure calculator for components and cladding. Pure TypeScript, zero dependencies.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.5.0"
  },
  "keywords": ["asce7", "wind-load", "wind-pressure", "calculator", "florida", "building-code", "engineering"],
